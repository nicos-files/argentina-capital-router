# Private/local manual snapshots and generated outputs.
# Templates and examples under config/ remain committed; only real, private
# user-filled snapshots under snapshots/ are ignored.
snapshots/market/*.json
snapshots/portfolio/*.json
snapshots/manual_execution/*.json
snapshots/outputs/*
!snapshots/market/.gitkeep
!snapshots/portfolio/.gitkeep
!snapshots/manual_execution/.gitkeep
!snapshots/outputs/.gitkeep
